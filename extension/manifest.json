{
  "manifest_version": 3,
  "name": "Nintendo Music Discord RPC",
  "version": "0.1",
  "description": "Detecta lo que se esta reproduciendo enNintendo Music y lo manda a Formato RPC de Discord",
  "permissions": ["tabs"],
  "host_permissions": [
  "https://music.nintendo.com/*",
  "http://127.0.0.1:35645/*"
],
  "content_scripts": [
    {
      "matches": ["https://music.nintendo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}